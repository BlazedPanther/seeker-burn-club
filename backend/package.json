{
  "name": "seeker-burn-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Seeker Burn Club — Backend API for daily SKR burns, streaks, badges, and leaderboards",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "tsx --test tests/*.test.ts",
    "migrate": "tsx src/db/migrate.ts",
    "generate:creatures": "tsx scripts/generate-creatures.ts",

    "audit:rarity": "tsx scripts/audit-rarity-balance.ts",
    "audit:prod": "npm audit --omit=dev",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@solana/web3.js": "^1.95.3",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.33.0",
    "fastify": "^5.8.1",
    "ioredis": "^5.4.1",
    "nanoid": "^5.0.7",
    "omggif": "^1.0.10",
    "pino": "^9.3.2",
    "postgres": "^3.4.4",
    "tweetnacl": "^1.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.19.13",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.8.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
